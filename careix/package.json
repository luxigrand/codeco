{
  "name": "careix",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build -w @careix/shared",
    "dev": "npm run dev --workspaces --if-present",
    "dev:api": "npm run dev -w @careix/api",
    "dev:web": "npm run dev -w @careix/web",
    "build": "npm run build --workspaces --if-present",
    "db:migrate": "npm run db:migrate -w @careix/api",
    "db:generate": "npm run db:generate -w @careix/api"
  }
}
